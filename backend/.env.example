# AI Mock Interview Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Tavus CVI ───────────────────────────────────────────────────
TAVUS_API_KEY=
TAVUS_REPLICA_ID=rf4e9d9790f0

# ── Google Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Sarvam AI (optional TTS) ─────────────────────────────────────
SARVAM_API_KEY=

# ── Server ───────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Session ──────────────────────────────────────────────────────
SESSION_TTL_SECONDS=7200

# ── Upload limits ────────────────────────────────────────────────
MAX_RESUME_SIZE_MB=5
MAX_RECORDING_SIZE_MB=500

# ── Recordings ───────────────────────────────────────────────────
# Path where interview recordings will be saved
RECORDINGS_DIR=./uploads
# Transcript service: none, google, assemblyai, deepgram
TRANSCRIPTION_SERVICE=none
TRANSCRIPTION_API_KEY=
